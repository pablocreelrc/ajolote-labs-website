# Cloudflare Pages headers — authoritative production policy.
# Ported from vercel.json (Vercel is preview-only; CF Pages is production).
# Syntax: https://developers.cloudflare.com/pages/configuration/headers/

# ----- Redesign previews: no-index, no-cache -----
/redesigns/*
  Cache-Control: no-store
  X-Robots-Tag: noindex

# ----- Images: long cache -----
/img/*
  Cache-Control: public, max-age=31536000, immutable

# ----- Favicon: short cache -----
/favicon.ico
  Cache-Control: public, max-age=86400

# ----- Global security headers -----
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: https:; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self' https://calendly.com
