# OS + editor
.DS_Store
Thumbs.db
*.log

# Dependencies (regenerated from package.json)
node_modules/
package-lock.json

# Deploy platforms (Vercel is preview-only; prod is Cloudflare Pages)
.vercel

# Claude Code local config (may contain secrets)
.claude/settings.local.json

# Git worktrees (isolated feature branches)
.worktrees/

# Brand references — kept local, not ingested by Claude Design
brand-references/

# =====================================================================
# Session artifacts — exploration screenshots, probe scripts, throwaway
# captures generated by Playwright/MCP audits. Never committed; the
# `audit.js` script regenerates what's useful into docs/audit/ on demand.
# =====================================================================

# Underscore-prefixed audit batches (legacy pattern)
_audit-*
_mobile-*
_verify-*
_preview-*
_cto-*
_live-*
_final-*
_re-*
_lh*.json
_reaudit.mjs
_responsive-audit.mjs
_audit/

# Session-scoped Playwright walkthroughs
fx-walkthrough/

# Dated exploration directories (neural-network experiments, audit batches)
audit-2026-*/

# Audit probe scripts + screenshot batches under docs/audit/
docs/audit/probe-*.js
docs/audit/capture-*.js
docs/audit/desktop-audit-capture.js
docs/audit/screenshots-*/
docs/audit/desktop-audit/
docs/audit/live-final/
docs/audit/ref-*.png
docs/audit/v1-preview.png
docs/audit/v2-preview.png
docs/audit/v3-preview.png
docs/audit/v3-templates.png
docs/audit/v3-updated.png

# Session-scoped tooling scripts (audits, walkthroughs, debug helpers)
scripts/

# Superpowers planning docs — internal, not site content
.superpowers/
docs/superpowers/

# Legacy reference snapshots (kept for diffs, never deployed)
docs/legacy-*.html
