# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# OS + editor
.DS_Store
Thumbs.db
*.log
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Deploy platforms (Vercel is not used in production; prod is Cloudflare Pages)
.vercel

# Claude Code local config (may contain secrets)
.claude/settings.local.json

# Git worktrees (isolated feature branches)
.worktrees/

# Brand references — kept local, not ingested by Claude Design
brand-references/

# Session-scoped Playwright/audit artifacts — local only
fx-walkthrough/
audit-2026-*/

# Superpowers planning docs — internal, not site content
.superpowers/

# typescript
*.tsbuildinfo
next-env.d.ts
